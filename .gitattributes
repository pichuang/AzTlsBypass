# Default: LF for all text files
* text=auto eol=lf

# PowerShell scripts: CRLF (Windows native)
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf
*.cmd   text eol=crlf
*.bat   text eol=crlf

# Python / docs: LF
*.py    text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary
*.crt   binary
*.pem   binary
*.zip   binary
*.whl   binary
